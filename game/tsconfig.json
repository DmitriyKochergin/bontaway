{
  "compilerOptions": {
    "types": ["@rsbuild/core/types"],
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "target": "ES2020",
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    /* modules */
    "module": "ESNext",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "Bundler",
    /* type checking */
    "strict": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
